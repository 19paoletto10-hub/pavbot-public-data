<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.pavbot.cloudflared</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>cloudflared tunnel --config /Users/YOU/.cloudflared/pavbot-notifier.yml run pavbot-notifier</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>KeepAlive</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/tmp/com.pavbot.cloudflared.out.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/com.pavbot.cloudflared.err.log</string>
</dict>
</plist>
