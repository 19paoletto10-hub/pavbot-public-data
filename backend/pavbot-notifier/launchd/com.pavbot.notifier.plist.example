<?xml version="1.0" encoding="UTF-8"?>
<!DOCTYPE plist PUBLIC "-//Apple//DTD PLIST 1.0//EN" "http://www.apple.com/DTDs/PropertyList-1.0.dtd">
<plist version="1.0">
<dict>
  <key>Label</key>
  <string>com.pavbot.notifier</string>
  <key>ProgramArguments</key>
  <array>
    <string>/bin/zsh</string>
    <string>-lc</string>
    <string>cd /Users/YOU/Documents/CODEX-Pavbot/backend/pavbot-notifier &amp;&amp; docker compose up -d --build</string>
  </array>
  <key>RunAtLoad</key>
  <true/>
  <key>StandardOutPath</key>
  <string>/tmp/com.pavbot.notifier.out.log</string>
  <key>StandardErrorPath</key>
  <string>/tmp/com.pavbot.notifier.err.log</string>
</dict>
</plist>
